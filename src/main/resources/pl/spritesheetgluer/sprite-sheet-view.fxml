<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" alignment="TOP_LEFT" xmlns:fx="http://javafx.com/fxml"
      fx:controller="pl.spritesheetgluer.ui.SpriteSheetController">
  <padding>
    <Insets bottom="18.0" left="18.0" right="18.0" top="18.0"/>
  </padding>

  <Label text="Sprite Sheet Gluer" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

  <TabPane tabClosingPolicy="UNAVAILABLE">
    <tabs>
      <Tab text="Frames to Sheet">
        <VBox spacing="14.0" alignment="TOP_LEFT">
          <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
          </padding>

          <VBox spacing="10.0">
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Root folder:"/>
              <TextField fx:id="rootField" editable="false" HBox.hgrow="ALWAYS"/>
              <Button text="Browse..." onAction="#onBrowse"/>
            </HBox>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Cell size:"/>
              <Label text="Must be uniform (no scaling)"/>
            </HBox>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Button fx:id="generateButton" text="Generate sprite sheets" onAction="#onGenerate"/>
            </HBox>
          </VBox>

          <Label text="Log"/>
          <TextArea fx:id="logArea" prefRowCount="12" wrapText="true" editable="false"/>
        </VBox>
      </Tab>
      <Tab text="Loose Files by Prefix">
        <VBox spacing="14.0" alignment="TOP_LEFT">
          <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
          </padding>

          <VBox spacing="10.0">
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Frame folder:"/>
              <TextField fx:id="looseRootField" editable="false" HBox.hgrow="ALWAYS"/>
              <Button text="Browse..." onAction="#onBrowseLooseRoot"/>
            </HBox>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Frame size:"/>
              <TextField fx:id="looseCellWidthField" prefWidth="72.0" text="128"/>
              <Label text="x"/>
              <TextField fx:id="looseCellHeightField" prefWidth="72.0" text="256"/>
            </HBox>
            <Label wrapText="true"
                   text="Loose images are grouped by the file-name prefix before the first separator or digits. Example: Stone 01.png, Stone_02.png, StoneB03.png -> Stone-sheet.png"/>
            <Label wrapText="true"
                   text="Only images matching the selected frame size are included. Large groups are split automatically to stay within Godot's 16384x16384 texture limit."/>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Button fx:id="looseGenerateButton" text="Generate grouped sheets" onAction="#onGenerateLooseSheets"/>
            </HBox>
          </VBox>

          <Label text="Log"/>
          <TextArea fx:id="looseLogArea" prefRowCount="12" wrapText="true" editable="false"/>
        </VBox>
      </Tab>
      <Tab text="Merge Existing Sheets">
        <VBox spacing="14.0" alignment="TOP_LEFT">
          <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0"/>
          </padding>

          <VBox spacing="10.0">
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Sheet folder:"/>
              <TextField fx:id="mergeRootField" editable="false" HBox.hgrow="ALWAYS"/>
              <Button text="Browse..." onAction="#onBrowseMergeRoot"/>
            </HBox>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Label text="Frame size:"/>
              <TextField fx:id="mergeCellWidthField" prefWidth="72.0" text="128"/>
              <Label text="x"/>
              <TextField fx:id="mergeCellHeightField" prefWidth="72.0" text="128"/>
            </HBox>
            <Label wrapText="true"
                   text="Each image in the selected folder is treated as an existing sprite sheet. Valid sheets are packed into a compact merged atlas in file name order while staying within Godot's texture-size limit when possible."/>
            <HBox spacing="8.0" alignment="CENTER_LEFT">
              <Button fx:id="mergeButton" text="Merge sprite sheets" onAction="#onMergeSheets"/>
            </HBox>
          </VBox>

          <Label text="Log"/>
          <TextArea fx:id="mergeLogArea" prefRowCount="12" wrapText="true" editable="false"/>
        </VBox>
      </Tab>
    </tabs>
  </TabPane>
</VBox>
